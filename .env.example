# === 共通 ===
API_SECRET=                          # Bearer認証トークン（data, fundamentals, disclosure で必須）

# === moomoo (data, collector) ===
OPEND_HOST=host.docker.internal
OPEND_PORT=11111
TRADE_ENV=SIMULATE                   # SIMULATE / REAL
TRADE_PASSWORD=

# === ブローカー切替 (data) ===
BROKER_TYPE=moomoo                   # moomoo / kabu

# === kabuステーション (data, BROKER_TYPE=kabu 時) ===
KABU_API_PASSWORD=
KABU_HOST=host.docker.internal
KABU_PORT=18080

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Collector ===
DB_PATH=/data/klines.db
WATCHLIST_PATH=watchlist.yml
LOOP_INTERVAL=30

# === J-Quants (collector, fundamentals) ===
JQUANTS_REFRESH_TOKEN=

# === Fundamentals ===
WATCHLIST_CODES=                     # カンマ区切り (例: 72030,86970)

# === EDINET (disclosure) ===
EDINET_API_KEY=
